# Web3 Wallet (optional — enables dApp/MetaMask interaction)
WALLET_PRIVATE_KEY=
WALLET_MNEMONIC=""
WALLET_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key_here
WALLET_CHAIN_ID=11155111
WALLET_METAMASK_EXTENSION_PATH=
# Optional but recommended for real MetaMask popups/signing flows
WALLET_METAMASK_USER_DATA_DIR=

# ─── Paystack (optional — enables Naira account + transfers) ──────────────────
#
# Get your keys from: https://dashboard.paystack.com/#/settings/developers
# Use sk_test_* / pk_test_* for sandbox testing.
# Use sk_live_* / pk_live_* for production (real money).
#
PAYSTACK_SECRET_KEY=sk_test_8e9a511381f9da902c861b86dab1d94ce7970cb6
PAYSTACK_PUBLIC_KEY=pk_test_613dc83b1ef6a1e72626a67d47b3c5a04ddd9fef

# DVA provider bank — either "wema-bank" or "guaranty-trust-bank"
# Contact Paystack support to confirm which is enabled on your account.
PAYSTACK_DVA_PROVIDER=wema-bank

# Identity for the agent's Paystack customer record
PAYSTACK_AGENT_EMAIL=agent@site-agent-pro.com
PAYSTACK_AGENT_FIRST_NAME=Site
PAYSTACK_AGENT_LAST_NAME=Agent

# Set to true ONLY when you are ready to send real Naira transfers.
# When false (default), sendMoney() logs the transfer details but does NOT
# submit to Paystack — safe for local testing and CI.
PAYSTACK_TRANSFER_ENABLED=false

# Webhook secret — must match the secret set in your Paystack dashboard
# under Settings → Webhooks. Used to verify incoming webhook signatures.
# If left blank, all incoming webhook requests will be rejected.
PAYSTACK_WEBHOOK_SECRET=
