LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5
OPENAI_TEMPERATURE=
OPENAI_MAX_TOKENS=

# 0G Inference (optional decentralized GPU inference)
# LLM_PROVIDER=0g
# ZG_INFERENCE_BASE_URL=https://router-api.0g.ai/v1
# ZG_INFERENCE_API_KEY=
# OPENAI_MODEL=qwen3.6-plus
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
APP_BASE_URL=http://localhost:4173
SITE_AGENT_DATA_DIR=
HEADLESS=true
MAX_SESSION_DURATION_MS=600000
MAX_STEPS_PER_TASK=32
ACTION_DELAY_MS=600
NAVIGATION_TIMEOUT_MS=25000
REPORT_TTL_DAYS=30
PLAYWRIGHT_STORAGE_STATE_PATH=
DASHBOARD_PORT=4173
DASHBOARD_HOST=127.0.0.1
AUTH_TEST_EMAIL=
AUTH_TEST_USERNAME=
AUTH_TEST_PASSWORD=
AUTH_TEST_FIRST_NAME=Site
AUTH_TEST_LAST_NAME=Agent
AUTH_TEST_PHONE=+12025550123
AUTH_TEST_ADDRESS_LINE1=123 Test Lane
AUTH_TEST_ADDRESS_LINE2=Suite 100
AUTH_TEST_CITY=Austin
AUTH_TEST_STATE=Texas
AUTH_TEST_POSTAL_CODE=78701
AUTH_TEST_COUNTRY=United States
AUTH_TEST_COMPANY=Site Agent QA
AUTH_IMAP_HOST=
AUTH_IMAP_PORT=993
AUTH_IMAP_SECURE=true
AUTH_IMAP_USER=
AUTH_IMAP_PASSWORD=
AUTH_IMAP_MAILBOX=INBOX
AUTH_EMAIL_POLL_TIMEOUT_MS=180000
AUTH_EMAIL_POLL_INTERVAL_MS=5000
AUTH_OTP_LENGTH=6
AUTH_EMAIL_FROM_FILTER=
AUTH_EMAIL_SUBJECT_FILTER=
AUTH_GENERATED_IDENTITY_MAX_ATTEMPTS=5
AUTH_EMAIL_DOMAIN=
AUTH_SIGNUP_URL=
AUTH_LOGIN_URL=
AUTH_ACCESS_URL=
AUTH_SESSION_STATE_PATH=.auth/session.json

# Web3 Wallet (optional — enables dApp/MetaMask interaction)
WALLET_PRIVATE_KEY=
WALLET_MNEMONIC=""
WALLET_RPC_URL=
WALLET_CHAIN_ID=11155111
WALLET_METAMASK_EXTENSION_PATH=
# Optional but recommended for real MetaMask popups/signing flows
WALLET_METAMASK_USER_DATA_DIR=

# 0G Proof (optional — stores audit evidence in 0G Storage and registers it on 0G Chain)
ZG_PROOF_ENABLED=false
ZG_NETWORK=galileo
ZG_PRIVATE_KEY=
ZG_CHAIN_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZG_AUDIT_REGISTRY_ADDRESS=
ZG_EXPLORER_URL=https://chainscan-galileo.0g.ai
ZG_PROOF_TIMEOUT_MS=120000
# HackQuest mainnet submission: set ZG_NETWORK=mainnet, use https://evmrpc.0g.ai,
# https://chainscan.0g.ai, and a valid mainnet 0G Storage indexer RPC.
